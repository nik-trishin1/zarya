# Copy to .env and fill in values

# Local dev (no Docker): SQLite — works out of the box
DATABASE_URL=sqlite+aiosqlite:///./zarya.db
DEV_MODE=true

# Production (Railway): use PostgreSQL instead
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/zarya
# DEV_MODE=false

BOT_TOKEN=your-telegram-bot-token
ADMIN_TELEGRAM_IDS=123456789
WEBAPP_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173,https://web.telegram.org
SECRET_KEY=change-me-in-production
