# Copy to .env and fill in values

# Local dev (no Docker): SQLite — works out of the box
DATABASE_URL=sqlite+aiosqlite:///./zarya.db
DEV_MODE=true

# Production (Railway): use PostgreSQL instead
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/zarya
# DEV_MODE=false

# Leave empty for local dev without Telegram bot (API + Mini App in browser still work)
BOT_TOKEN=
# Optional: Direct Link Mini App short name from BotFather (omit for Main Mini App)
BOT_APP_SHORT_NAME=
ADMIN_TELEGRAM_IDS=
# Your numeric Telegram ID — get it via /myid in the bot or @userinfobot
# Do NOT leave the example value 123456789
WEBAPP_URL=http://localhost:5173
API_BASE_URL=http://localhost:8000
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173,https://web.telegram.org
SECRET_KEY=change-me-in-production
