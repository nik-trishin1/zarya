# Runtime variable on Railway (frontend service) — public URL of the BACKEND
# Scheme optional: zarya-production-be.up.railway.app is normalized to https://...
API_UPSTREAM=https://your-backend.up.railway.app

# Optional: only if not using nginx proxy (leave empty in production)
VITE_API_URL=

# Bot @username without @ — used for event share deep links (production: zarya_friends_bot)
VITE_BOT_USERNAME=zarya_friends_bot

# Optional: Direct Link Mini App short name from BotFather (omit for Main Mini App only)
# VITE_BOT_APP_SHORT_NAME=
